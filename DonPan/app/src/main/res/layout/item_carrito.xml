<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tv_nombre_carrito"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="Pan Integral Orgánico"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tv_precio_unitario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Precio unitario: $2000"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/btn_restar_cantidad"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="-"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/tv_cantidad_carrito"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="2"/>

        <Button
            android:id="@+id/btn_sumar_cantidad"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="+"
            android:layout_marginStart="4dp"/>

        <TextView
            android:id="@+id/tv_subtotal_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textSize="16sp"
            android:textStyle="italic"
            tools:text="Subtotal: $4000"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray"
        android:layout_marginTop="8dp"/>

</LinearLayout>